{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ESP32 Firmware",
      "type": "shell",
      "command": "${workspaceFolder}/esp32/build_wokwi.bat",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "คอมไพล์ ESP32 sketch → build/ (รัน build_wokwi.bat ที่ติดตั้ง dependencies อัตโนมัติ)"
    },
    {
      "label": "Build ESP32 Firmware (arduino-cli direct)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--fqbn", "esp32:esp32:esp32",
        "--output-dir", "${workspaceFolder}/esp32/build",
        "${workspaceFolder}/esp32"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "คอมไพล์โดยตรงผ่าน arduino-cli (ต้อง open Terminal ใหม่หลัง install)"
    },
    {
      "label": "ESP32 Setup: Install Board + Libraries",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "config", "add", "board_manager.additional_urls",
        "https://raw.githubusercontent.com/espressif/arduino-esp32/gh-pages/package_esp32_index.json"
      ],
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": [],
      "detail": "เพิ่ม ESP32 board URL (ทำครั้งเดียว)"
    }
  ]
}
