{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/compile_manual.js && node --max-old-space-size=4096 --no-deprecation node_modules/next/dist/bin/next dev",
    "dev:turbo": "node scripts/compile_manual.js && node --max-old-space-size=4096 --no-deprecation node_modules/next/dist/bin/next dev --turbopack",
    "build": "node scripts/compile_manual.js && node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; Write-Host 'Cache cleaned successfully'\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@vercel/kv": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.17.0",
    "next": "16.3.0-canary.29",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-canary.29",
    "marked": "^18.0.4",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
